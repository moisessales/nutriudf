# ============ DATABASE ============
DB_HOST=localhost
DB_PORT=3306
DB_USER=nutriudf_app
DB_PASSWORD=SUA_SENHA_FORTE_AQUI
DB_NAME=nutriudf

# ============ SERVER ============
PORT=3000
NODE_ENV=production

# ============ JWT ============
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=GERE_UM_SECRET_COM_O_COMANDO_ACIMA
JWT_EXPIRE=7d

# ============ CORS ============
# Em produção, coloque o domínio real. Múltiplos: separar por vírgula
CORS_ORIGIN=https://seudominio.com

# ============ EMAIL (SMTP) ============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_app_password_google
EMAIL_FROM=noreply@seudominio.com
EMAIL_FROM_NAME=NutriApp
APP_URL=https://seudominio.com
